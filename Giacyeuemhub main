-- Hàm bay đến tọa độ chỉ định (Tween)
function topos(targetCFrame)
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local root = char.HumanoidRootPart
        local dist = (targetCFrame.Position - root.Position).Magnitude
        local tweenTime = dist / _G.TweenSpeed
        
        -- Dừng tween cũ nếu đang bay
        if _G.CurrentTween then _G.CurrentTween:Cancel() end
        
        local info = TweenInfo.new(tweenTime, Enum.EasingStyle.Linear)
        _G.CurrentTween = game:GetService("TweenService"):Create(root, info, {CFrame = targetCFrame})
        _G.CurrentTween:Play()
    end
end

