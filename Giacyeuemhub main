function BuyMeleeTween(TargetCFrame, MeleeID)
    _G.FarmBone = false -- Tắt farm để đi mua đồ
    
    task.spawn(function()
        local player = game.Players.LocalPlayer
        local remote = game:GetService("ReplicatedStorage").Remotes.CommF_
        
        -- Bắt đầu bay
        topos(TargetCFrame)
        
        -- Đợi cho đến khi đứng sát NPC (khoảng cách < 15)
        repeat 
            task.wait(0.5) 
        until (player.Character.HumanoidRootPart.Position - TargetCFrame.Position).Magnitude < 15 or not _G.CurrentTween
        
        -- Khi đã đến nơi, gửi lệnh mua tùy theo ID
        if MeleeID == "BlackLeg" then remote:InvokeServer("BuyBlackLeg")
        elseif MeleeID == "Electro" then remote:InvokeServer("BuyElectro")
        elseif MeleeID == "WaterKungFu" then remote:InvokeServer("BuyFishmanKarate")
        elseif MeleeID == "DragonClaw" then remote:InvokeServer("BuyDragonClaw")
        elseif MeleeID == "Superhuman" then remote:InvokeServer("BuySuperhuman")
        elseif MeleeID == "DeathStep" then remote:InvokeServer("BuyDeathStep")
        elseif MeleeID == "Sharkman" then 
            remote:InvokeServer("BuySharkmanKarate", true)
            remote:InvokeServer("BuySharkmanKarate")
        elseif MeleeID == "ElectricClaw" then remote:InvokeServer("BuyElectricClaw")
        elseif MeleeID == "DragonTalon" then remote:InvokeServer("BuyDragonTalon")
        elseif MeleeID == "Godhuman" then remote:InvokeServer("BuyGodhuman")
        end
        
        print("Đã mua thành công: " .. MeleeID)
    end)
end

