-- Hàm tool --
function EquipWeapon(WeaponType)
    pcall(function()
        local backpack = game.Players.LocalPlayer.Backpack
        local character = game.Players.LocalPlayer.Character
        if not character then return end
        
        for _, v in pairs(character:GetChildren()) do
            if v:IsA("Tool") and (v.ToolTip == WeaponType or (WeaponType == "Blox Fruit" and v.ToolTip == "Go")) then
                return 
            end
        end
        for _, v in pairs(backpack:GetChildren()) do
            if v:IsA("Tool") and (v.ToolTip == WeaponType or (WeaponType == "Blox Fruit" and v.ToolTip == "Go")) then
                character.Humanoid:EquipTool(v)
            end
        end
    end)
end

-- Hàm Tween
function topos(targetCFrame)
    local char = game.Players.LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Lấy tốc độ mặc định nếu biến bị lỗi
    local speed = _G.TweenSpeed or 250
    local dist = (targetCFrame.Position - root.Position).Magnitude
    
    -- 1. Nếu đang bay đến mục tiêu cũ thì KHÔNG làm gì cả (Chống giật/khựng)
    if _G.CurrentTween and _G.LastTargetPos then
        local lech = (targetCFrame.Position - _G.LastTargetPos.Position).Magnitude
        if lech < 5 then return end -- Nếu mục tiêu lệch ít hơn 5 unit thì cứ để nó bay tiếp
    end

    -- 2. Dừng cái cũ để chuyển mục tiêu mới
    StopTween()

    -- 3. Nếu khoảng cách quá gần (< 15) thì dịch chuyển thẳng luôn cho nhanh
    if dist < 15 then 
        root.CFrame = targetCFrame 
        return 
    end

    -- 4. Tạo Tween mới
    _G.LastTargetPos = targetCFrame
    local info = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
    _G.CurrentTween = game:GetService("TweenService"):Create(root, info, {CFrame = targetCFrame})
    
    _G.CurrentTween.Completed:Connect(function()
        _G.LastTargetPos = nil
        _G.CurrentTween = nil
    end)

    _G.CurrentTween:Play()
end

function StopTween()
    if _G.CurrentTween then
        _G.CurrentTween:Cancel()
        _G.CurrentTween = nil
    end
    _G.LastTargetPos = nil
    
    -- Ép nhân vật dừng lại ngay lập tức (Chống nhặt thêm rương)
    local root = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        root.Velocity = Vector3.new(0, 0, 0)
    end
end

