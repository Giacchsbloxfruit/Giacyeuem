local function GetSeaBeastTrial()
    if not workspace.Map:FindFirstChild("FishmanTrial") then return nil end
    local waterTrial = workspace._WorldOrigin.Locations:FindFirstChild("Trial of Water")
    if waterTrial then
        for _, v in pairs(workspace.SeaBeasts:GetChildren()) do
            if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Health") and v.Health.Value > 0 then
                if (v.HumanoidRootPart.Position - waterTrial.Position).Magnitude <= 1500 then
                    return v
                end
            end
        end
    end
    return nil
end

