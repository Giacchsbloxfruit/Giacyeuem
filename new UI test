-- Hàm Gom Quái (Bring Mob) - Tầm 2-4 con gần nhất
function BringMob(targetMobName, targetPos)
    if not _G.BringMob then return end
    pcall(function()
        local count = 0
        -- QUAN TRỌNG 1: Chiếm quyền điều khiển mạng của quái để Server công nhận vị trí
        sethiddenproperty(game.Players.LocalPlayer, "SimulationRadius", math.huge)

        for _, v in pairs(workspace.Enemies:GetChildren()) do
            if v.Name == targetMobName and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                if count < 4 then
                    -- QUAN TRỌNG 2: Tắt va chạm toàn bộ cơ thể để không bị cấn đất (gây văng/bay)
                    for _, part in pairs(v:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end

                    v.HumanoidRootPart.CFrame = targetPos
                    
                    -- QUAN TRỌNG 3: Triệt tiêu mọi lực văng hiện có của quái
                    v.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                    
                    v.Humanoid.WalkSpeed = 0
                    v.Humanoid.JumpPower = 0 -- Khóa nhảy để quái không thoát khỏi CFrame

                    -- QUAN TRỌNG 4: Đổi từ State 11 sang 14. 
                    -- State 14 (Physics) giúp quái đứng im re tại vị trí CFrame mà không bị Server kéo lại
                    if v.Humanoid:GetState() ~= Enum.HumanoidStateType.Physics then
                        v.Humanoid:ChangeState(14)
                    end

                    count = count + 1
                end
            end
        end
    end)
end
