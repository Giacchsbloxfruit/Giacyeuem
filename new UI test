-- Hàm đổi giây sang định dạng 00:00:00
local function FormatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local mins = math.floor((seconds % 3600) / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", hours, mins, secs)
end

RunService.RenderStepped:Connect(function()
    -- Hiệu ứng Rainbow cho chữ
    local hue = tick() % 3 / 3
    InfoLabel.TextColor3 = Color3.fromHSV(hue, 1, 1)
    
    -- Tính FPS
    local CurrentTime = tick()
    for i = #TimeTable, 1, -1 do
        if TimeTable[i] < CurrentTime - 1 then
            table.remove(TimeTable, i)
        end
    end
    table.insert(TimeTable, CurrentTime)
    
    -- Cập nhật nội dung mỗi 0.5 giây
    if CurrentTime - LastUpdate >= FrameUpdateDelay then
        local fps = #TimeTable
        local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        local elapsed = CurrentTime - StartTime
        
        InfoLabel.Text = string.format("FPS: %d | Ping: %d ms | Time: %s", fps, ping, FormatTime(elapsed))
        LastUpdate = CurrentTime
    end
end)

