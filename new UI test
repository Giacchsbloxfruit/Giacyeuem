task.spawn(function()
    while task.wait() do
        if _G.AutoFarmLevel then
            pcall(function()
                local player = game.Players.LocalPlayer
                local currentLevel = player.Data.Level.Value
                local questData = GetMobByLevel(currentLevel)
                
                if questData then
                    local questGui = player.PlayerGui.Main.Quest
                    local hasQuest = questGui.Visible
                    local currentQuestText = hasQuest and questGui.Container.QuestTitle.Title.Text or ""
                    
                    -- KIỂM TRA & NHẬN NHIỆM VỤ
                    if not hasQuest or not string.find(currentQuestText, questData.Mon) then
                        -- Đang nhận sai Quest thì Hủy
                        if hasQuest then
                            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("AbandonQuest")
                        end
                        
                        -- Bay đến NPC giao Quest
                        if (player.Character.HumanoidRootPart.Position - questData.PosQ.Position).Magnitude > 10 then
                            topos(questData.PosQ)
                        else
                            -- Tới nơi thì nhận Quest
                            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", questData.Qname, questData.Qdata)
                        end
                    else
                        -- ĐÃ CÓ QUEST -> ĐI FARM QUÁI
                        local enemies = game:GetService("Workspace").Enemies
                        local targetMob = nil
                        
                        -- Tìm con quái còn sống
                        for _, mob in ipairs(enemies:GetChildren()) do
                            if mob.Name == questData.Mon and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                                targetMob = mob
                                break
                            end
                        end
                        
                        if targetMob then
                            -- Trang bị vũ khí
                            EquipWeapon(_G.SelectWeapon)
                            
                            -- Bay đến đỉnh đầu quái, cố định cách 30m
                            topos(targetMob.HumanoidRootPart.CFrame * CFrame.new(0, 30, 0))
                            
                            -- Auto Click chém quái
                            game:GetService("VirtualUser"):Button1Down(Vector2.new(1280, 670))
                            
                            -- Gom quái (Bring Mob)
                            if _G.BringMob then
                                for _, otherMob in ipairs(enemies:GetChildren()) do
                                    if otherMob.Name == questData.Mon and otherMob:FindFirstChild("Humanoid") and otherMob.Humanoid.Health > 0 then
                                        -- Nếu quái khác trong phạm vi 250m thì kéo nó tới
                                        if (otherMob.HumanoidRootPart.Position - targetMob.HumanoidRootPart.Position).Magnitude < 250 then
                                            otherMob.HumanoidRootPart.CFrame = targetMob.HumanoidRootPart.CFrame
                                            otherMob.Humanoid.WalkSpeed = 0
                                            otherMob.Humanoid.JumpPower = 0
                                        end
                                    end
                                end
                            end
                        else
                            -- Nếu hết quái hoặc chưa spawn, bay lơ lửng cách mặt đất bãi quái 30m để chờ
                            topos(questData.PosM * CFrame.new(0, 30, 0))
                        end
                    end
                end
            end)
        end
    end
end)

