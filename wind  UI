local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()
local Window = WindUI:CreateWindow({
    Title = "My Super Hub",
    Icon = "door-open", -- lucide icon
    Author = "by .ftgs and .ftgs",
    Folder = "MySuperHub",
    
    -- ↓ This all is Optional. You can remove it.
    Size = UDim2.fromOffset(580, 460),
    MinSize = Vector2.new(560, 350),
    MaxSize = Vector2.new(850, 560),
    ToggleKey = Enum.KeyCode.LeftShift,
    Transparent = true,
    Theme = "Dark",
    Resizable = true,
    SideBarWidth = 200,
    BackgroundImageTransparency = 0.42,
    HideSearchBar = true,
    ScrollBarEnabled = false,
    
    -- ↓ Optional. You can remove it.
    --[[ You can set 'rbxassetid://' or video to Background.
        'rbxassetid://':
            Background = "rbxassetid://", -- rbxassetid
        Video:
            Background = "video:YOUR-RAW-LINK-TO-VIDEO.webm", -- video 
    --]]
    
    -- ↓ Optional. You can remove it.
    User = {
        Enabled = true,
        Anonymous = true,
        Callback = function()
            print("clicked")
        end,
    },
})

local Main = Window:Tab({
    Title = "Main Farm",
    Icon = "house", -- optional
    Locked = false,
})

local Setting = Window:Tab({
    Title = "Setting Farm",
    Icon = "settings", -- optional
    Locked = false,
})
Main:Button({
    Title = "Nhận nhiệm vụ",
    Desc = "Tự động nhận nhiệm vụ gần nhất",
    Callback = function()
        print("Đã nhấn nút nhận nhiệm vụ!")
        -- Code của bạn ở đây
    end
})

Main:Toggle({
    Title = "Auto Farm Level",
    Value = false, -- Mặc định là Tắt
    Callback = function(state)
        _G.AutoFarm = state -- 'state' sẽ là true nếu bật, false nếu tắt
        
        if _G.AutoFarm then
            print("Đã bật Farm!")
            -- Chạy vòng lặp farm của bạn ở đây
        else
            print("Đã tắt Farm!")
        end
    end
})
-- Thêm vào Tab "Setting Farm"
Setting:Slider({
    Title = "Tốc độ chạy",
    Desc = "Chỉnh tốc độ di chuyển của nhân vật",
    Step = 1, -- Đây là bước nhảy, nếu thiếu slider có thể bị đứng
    Value = {
        Min = 16,
        Max = 300,
        Default = 100
    },
    Callback = function(v)
        -- 'v' là giá trị khi bạn kéo slider
        if game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid") then
            game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
        end
    end
})

local FarmSection = Main:Section({
    Title = "Cấu hình Auto Farm",
    Opened = true, -- Mặc định là mở ra
})

-- 2. Thêm Paragraph để hướng dẫn hoặc thông báo
Main:Paragraph({
    Title = "Thông tin Script",
    Desc = "Chào mừng bạn đến với My Super Hub. Chúc bạn chơi game vui vẻ!",
    Image = "rbxassetid://12345678", -- Bạn có thể đổi ID icon
    ImageSize = 25,
})

-- 3. Thêm Dropdown để chọn Vũ khí (Nằm trong Section)
FarmSection:Dropdown({
    Title = "Chọn Vũ Khí",
    Desc = "Chọn loại vũ khí bạn muốn dùng để Farm",
    Values = {"Combat", "Sword", "Fruit"},
    Value = {"Combat"}, -- Giá trị mặc định
    Multi = false,
    Callback = function(v)
        print("Vũ khí đã chọn: " .. v[1])
    end
})

-- 4. Thêm Button để nhận tất cả code (Redeem All Codes)
Main:Button({
    Title = "Nhập Tất Cả Codes",
    Desc = "Tự động nhập toàn bộ mã quà tặng còn hạn",
    Callback = function()
        print("Đang nhập codes...")
    end
})

-- ==========================================
-- TAB 2: SETTING FARM (Cài đặt & Giao diện)
-- ==========================================

-- 5. Thêm Colorpicker để đổi màu giao diện
Setting:Colorpicker({
    Title = "Màu chủ đạo",
    Desc = "Thay đổi màu sắc của Menu",
    Default = Color3.fromRGB(0, 255, 255),
    Callback = function(color)
        print("Màu mới: " .. tostring(color))
    end
})

-- 6. Thêm Slider (Đã sửa lỗi cấu trúc Value cho bạn)
Setting:Slider({
    Title = "Tốc độ chạy",
    Step = 1,
    Value = {
        Min = 16,
        Max = 300,
        Default = 100
    },
    Callback = function(v)
        if game.Players.LocalPlayer.Character then
            game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
        end
    end
})

-- 7. Thêm Code Element để hiển thị thông tin bản quyền hoặc script rời
Setting:Code({
    Title = "Thông tin Developer",
    Code = [[
-- Script được phát triển bởi: YourName
-- Version: 1.0.0
print("Cảm ơn bạn đã sử dụng!")
    ]]
})
