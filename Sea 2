    -- Ép chuyển Sea liên tục cho đến khi thành công
    while task.wait(2) do
        pcall(function() Remote:InvokeServer("TravelDressrosa") end)
        pcall(function() Remote:InvokeServer("TravelMain") end)
    end
end)
