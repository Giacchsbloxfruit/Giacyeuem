local player = game.Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")

-- 1. Giữ nguyên đường dẫn Remote thành công của bạn
local Remote = RS:FindFirstChild("CommF_", true) or (RS:FindFirstChild("Remotes") and RS.Remotes:FindFirstChild("CommF_"))

-- 2. Hàm kiểm tra chìa khóa
local function checkKey()
    return player.Backpack:FindFirstChild("Library Key") or player.Character:FindFirstChild("Library Key")
end

-- 3. Hàm Tween tự thân
local function tweenTo(pos)
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local noclip = game:GetService("RunService").Stepped:Connect(function()
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end)
    local dist = (root.Position - pos.Position).Magnitude
    local tween = game:GetService("TweenService"):Create(root, TweenInfo.new(dist/230, Enum.EasingStyle.Linear), {CFrame = pos})
    tween:Play()
    tween.Completed:Wait()
    noclip:Disconnect()
end

task.spawn(function()
    if player.Data.Level.Value < 700 then return end

    -- [[ BƯỚC 1: GIỮ NGUYÊN LOGIC LẤY KEY CỦA BẠN ]]
    if not checkKey() then
        print("--- Đang đi lấy Key (Logic thành công) ---")
        tweenTo(CFrame.new(4852, 6, 712)) 
        task.wait(1)

        for i = 1, 20 do 
            if checkKey() then break end
            task.wait(0.5)
            pcall(function()
                Remote:InvokeServer("ConfirmIceAbel")
                Remote:InvokeServer("DressrosaQuestProgress", "Detective")
                Remote:InvokeServer("Talk", "Military Detective")
            end)
            player.Character.HumanoidRootPart.CFrame = CFrame.new(4852, 6, 712) * CFrame.new(math.random(-1,1), 0, math.random(-1,1))
        end
    end

    -- ĐỢI ĐẾN KHI CHẮC CHẮN CÓ KEY TRÊN TAY/TÚI MỚI CHẠY TIẾP
    local keyWait = 0
    while not checkKey() and keyWait < 10 do
        task.wait(1)
        keyWait = keyWait + 1
        print("Đang xác nhận Key trong túi đồ...")
    end

    -- [[ BƯỚC 2: SỬA LẠI LOGIC DIỆT BOSS ]]
    if checkKey() then
        print("--- Đã có Key! Bay tới hang Băng ngay lập tức ---")
        
        -- Tọa độ hang Băng chuẩn Sea 1
        local iceAdmiralPos = CFrame.new(1347.6, 37.97, -1325.47)
        tweenTo(iceAdmiralPos)
        task.wait(1)

        -- Trang bị chìa khóa để chạm mở cửa
        local keyItem = player.Backpack:FindFirstChild("Library Key") or player.Character:FindFirstChild("Library Key")
        if keyItem then 
            player.Character.Humanoid:EquipTool(keyItem) 
            task.wait(2) -- Đợi 2 giây cầm key chạm cửa
        end

        -- Bắt đầu đánh Boss
        print("--- Đang diệt Boss Ice Admiral ---")
        local battleTime = os.time()
        while os.time() - battleTime < 90 do -- Tăng thời gian đánh lên 90s cho chắc
            local boss = workspace.Enemies:FindFirstChild("Ice Admiral") or workspace.Enemies:FindFirstChild("Ice Admiral [Lv. 700] [Boss]")
            
            if boss and boss:FindFirstChild("Humanoid") and boss.Humanoid.Health > 0 then
                for _, v in pairs(player.Backpack:GetChildren()) do
                    if v:IsA("Tool") and v.ToolTip == "Melee" then
                        player.Character.Humanoid:EquipTool(v) break
                    end
                end
                -- Bay đè lên đầu Boss
                player.Character.HumanoidRootPart.CFrame = boss.HumanoidRootPart.CFrame * CFrame.new(0, 20, 0)
                RS.Modules.Net["RE/RegisterAttack"]:FireServer(0)
                RS.Modules.Net["RE/RegisterHit"]:FireServer(boss.PrimaryPart, {{boss, boss.PrimaryPart}})
            else
                if not workspace.Enemies:FindFirstChild("Ice Admiral") and os.time() - battleTime > 10 then
                    print("Boss đã gục!")
                    break
                end
            end
            task.wait()
        end
        
        -- QUAY LẠI BÁO CÁO (NPC bắt buộc phải nói chuyện sau khi diệt Boss)
        print("Quay lại Prison báo cáo...")
        tweenTo(CFrame.new(4852, 6, 712))
        task.wait(1)
        pcall(function() Remote:InvokeServer("ConfirmIceAbel") end)
    else
        warn("Không có Key, dừng script để tránh bay lỗi!")
        return
    end

    -- [[ BƯỚC 3: TELEPORT SEA 2 KHÔNG CẦN TWEEN (SỬA THEO Ý BẠN) ]]
    print("--- DIỆT BOSS XONG! GỌI LỆNH TELEPORT SEA 2 TỨC THỜI ---")
    
    task.wait(1) -- Nghỉ 1 giây để game nhận diện boss chết

    pcall(function()
        -- Lệnh Teleport trực tiếp không qua trung gian
        Remote:InvokeServer("TravelDressrosa")
    end)
    
    -- Dự phòng lệnh 2
    task.wait(1)
    pcall(function()
        Remote:InvokeServer("TravelMain")
    end)

    print("--- ĐANG SANG SEA 2! ---")
end)
