--Loop travel
task.spawn(function()
    while task.wait(0.5) do
        -- 1. XỬ LÝ TWEEN
        if _G.AutoTweenIsland then
            pcall(function()
                local targetCF = Sea3Data.AllIslands[_G.SelectedIsland]
                local root = game.Players.LocalPlayer.Character.HumanoidRootPart
                local dist = (root.Position - targetCF.Position).Magnitude
                
                if dist > 15 then
                    -- Tắt farm để không bị kéo ngược
                    _G.FarmBone = false
                    _G.OldFarmBoneStatus = false
                    topos(targetCF)
                else
                    -- TỚI NƠI THÌ TỰ TẮT
                    _G.AutoTweenIsland = false
                    TweenToggle:SetValue(false) -- Cập nhật UI nút gạt về Off
                    if _G.CurrentTween then _G.CurrentTween:Cancel() end
                end
            end)
        else
            -- Tắt toggle thì dừng Tween ngay
            if not _G.AutoTweenIsland and _G.CurrentTween then
                _G.CurrentTween:Cancel()
                _G.CurrentTween = nil
            end
        end

        -- 2. XỬ LÝ PORTAL
        if _G.AutoPortalIsland then
            pcall(function()
                local targetPos = Sea3Data.Portals[_G.SelectedPortal]
                if targetPos then
                    _G.FarmBone = false
                    _G.OldFarmBoneStatus = false
                    if _G.CurrentTween then _G.CurrentTween:Cancel() end
                    
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("requestEntrance", targetPos)
                    
                    -- Dùng xong tự tắt luôn
                    _G.AutoPortalIsland = false
                    PortalToggle:SetValue(false)
                end
            end)
        end
    end
end)

