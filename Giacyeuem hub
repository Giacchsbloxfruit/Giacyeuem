-- Hàm Tween di chuyển mượt
function topos(targetCFrame)
    local character = game.Players.LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local rootPart = character.HumanoidRootPart
    local distance = (targetCFrame.p - rootPart.Position).Magnitude
    local duration = distance / _G.TweenSpeed
    
    -- Nếu khoảng cách quá gần thì TP thẳng cho nhanh
    if distance < 10 then
        rootPart.CFrame = targetCFrame
        return
    end

    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = targetCFrame})
    
    -- Dừng tween nếu tắt Farm
    if not _G.FarmBone then 
        tween:Cancel() 
        return 
    end
    
    tween:Play()
end

-- Hàm hỗ trợ TP nhanh (dùng khi khoảng cách quá xa)
function TP1(targetCFrame)
    pcall(function()
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = targetCFrame
    end)
end

