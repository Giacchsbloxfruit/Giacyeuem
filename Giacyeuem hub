-- 2. CÁC HÀM HỖ TRỢ (SUPPORT FUNCTIONS)
-- ==========================================
function AutoHaki()
    if not game:GetService("Players").LocalPlayer.Character:FindFirstChild("HasBuso") then
        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Buso");
    end
end

function EquipWeapon(WeaponType)
    pcall(function()
        local player = game.Players.LocalPlayer
        local character = player.Character
        local backpack = player.Backpack

        for _, v in pairs(character:GetChildren()) do
            if v:IsA("Tool") and (v.ToolTip == WeaponType or (WeaponType == "Blox Fruit" and v.ToolTip == "Go") or (WeaponType == "Melee" and v.ToolTip == "Melee")) then
                return
            end
        end

        for _, v in pairs(backpack:GetChildren()) do
            if v:IsA("Tool") then
                if WeaponType == "Melee" and v.ToolTip == "Melee" then
                    character.Humanoid:EquipTool(v)
                elseif WeaponType == "Sword" and v.ToolTip == "Sword" then
                    character.Humanoid:EquipTool(v)
                elseif WeaponType == "Gun" and v.ToolTip == "Gun" then
                    character.Humanoid:EquipTool(v)
                elseif WeaponType == "Blox Fruit" and v.ToolTip == "Go" then
                    character.Humanoid:EquipTool(v)
                end
            end
        end
    end)
end

