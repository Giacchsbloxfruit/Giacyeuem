-- Vòng lặp Farm Bone
task.spawn(function()
    while task.wait() do
        if _G.FarmBone then
            pcall(function()
                local spawnArea = CFrame.new(-9508.5, 142.1, 5737.3)
                local enemies = game:GetService("Workspace").Enemies:GetChildren()
                local foundMob = false
                
                for _, v in pairs(enemies) do
                    if (v.Name == "Reborn Skeleton" or v.Name == "Living Zombie" or v.Name == "Demonic Soul" or v.Name == "Posessed Mummy") 
                    and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        foundMob = true
                        repeat
                            task.wait()
                            AutoHaki()
                            EquipWeapon(_G.SelectWeapon)
                            
                            -- Bay trên đầu quái (tầm đánh ổn định)
                            local targetCF = v.HumanoidRootPart.CFrame * CFrame.new(0, 25, 0)
                            topos(targetCF)
                            
                            -- Kích hoạt gom quái
                            if _G.BringMob then
                                BringMob(v.Name, v.HumanoidRootPart.CFrame)
                            end
                            
                            -- Gom quái bằng simulation (hỗ trợ thêm)
                            sethiddenproperty(game.Players.LocalPlayer, "SimulationRadius", math.huge)
                        until not _G.FarmBone or not v.Parent or v.Humanoid.Health <= 0
                    end
                end
                
                if not foundMob then topos(spawnArea) end
            end)
        end
    end
end)

