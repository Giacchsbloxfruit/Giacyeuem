-- Logic Auto Farm Bone
spawn(function()
    while wait() do
        if _G.FarmBone and World3 then
            pcall(function()
                local boneArea = CFrame.new(-9508.5673828125, 142.1398468017578, 5737.3603515625)
                
                -- Kiểm tra quái trong Workspace
                local hasEnemies = false
                for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                    if (v.Name == "Reborn Skeleton" or v.Name == "Living Zombie" or v.Name == "Demonic Soul" or v.Name == "Posessed Mummy") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        hasEnemies = true
                        repeat
                            task.wait()
                            AutoHaki()
                            EquipWeapon(_G.SelectWeapon)
                            
                            -- Vô hiệu hóa va chạm để không bị kẹt
                            v.HumanoidRootPart.CanCollide = false
                            v.Humanoid.WalkSpeed = 0
                            
                            -- Tween đến quái (bay phía trên đầu 30 unit)
                            topos(v.HumanoidRootPart.CFrame * CFrame.new(0, 30, 0))
                            
                            -- Gom quái (SimulationRadius)
                            sethiddenproperty(game.Players.LocalPlayer, "SimulationRadius", math.huge)
                        until not _G.FarmBone or not v.Parent or v.Humanoid.Health <= 0
                    end
                end
                
                -- Nếu không có quái thì bay về khu vực trung tâm nghĩa địa
                if not hasEnemies then
                    topos(boneArea)
                end
            end)
        end
    end
end)

