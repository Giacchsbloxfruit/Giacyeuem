                    return -- Dừng lại để script Auto Attack riêng của bạn tự đấm Boss
                end

                -- BƯỚC 2: Nếu Gương đã mở -> Bay vào thẳng trong không gian Gương
                if bigMirror and bigMirror:FindFirstChild("Other") and bigMirror.Other.Transparency == 0 then
                    topos(CFrame.new(-2151.82, 149.32, -12404.91))
                    return
                end

                -- BƯỚC 3: Lấy thông tin số lượng quái
                local countStr = game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("CakePrinceSpawner")
                local mobsLeft = 500
                if type(countStr) == "string" then
                    local match = string.match(countStr, "%d+")
                    if match then mobsLeft = tonumber(match) end
                end

                -- BƯỚC 4: Logic Farm hoặc Triệu hồi
                if mobsLeft > 0 then
                    -- Nếu chưa đủ 500 con -> Tìm quái ở đảo Cake Loaf để TP tới
                    local targetMob = nil
                    local validMobs = {"Cookie Crafter", "Cake Guard", "Baking Staff", "Head Baker"}
                    
                    for _, mobName in ipairs(validMobs) do
                        local mob = enemies:FindFirstChild(mobName)
                        if mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                            targetMob = mob
                            break
                        end
                    end

                    if targetMob then
                        -- Bay đến trên đầu quái để Auto Attack đánh
                        topos(targetMob.HumanoidRootPart.CFrame * CFrame.new(0, 15, 0))
                    else
                        -- Không thấy quái thì đứng giữa đảo chờ quái spawn
                        topos(CFrame.new(-2077, 252, -12373))
                    end
