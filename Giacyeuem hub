function EquipWeapon(WeaponType)
    pcall(function()
        local backpack = game.Players.LocalPlayer.Backpack
        local character = game.Players.LocalPlayer.Character
        if not character then return end
        
        for _, v in pairs(character:GetChildren()) do
            if v:IsA("Tool") and (v.ToolTip == WeaponType or (WeaponType == "Blox Fruit" and v.ToolTip == "Go")) then
                return 
            end
        end
        for _, v in pairs(backpack:GetChildren()) do
            if v:IsA("Tool") and (v.ToolTip == WeaponType or (WeaponType == "Blox Fruit" and v.ToolTip == "Go")) then
                character.Humanoid:EquipTool(v)
            end
        end
    end)
end

-- Hàm Noclip & Chống rơi "Thông minh"
RunService.Stepped:Connect(function()
    -- Chỉ hoạt động khi có Tween đang chạy (Farm, Đánh Boss, Nhặt trái...)
    if _G.CurrentTween and (_G.CurrentTween.PlaybackState == Enum.PlaybackState.Playing or _G.CurrentTween.PlaybackState == Enum.PlaybackState.Delayed) then
        pcall(function()
            local char = game.Players.LocalPlayer.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")

                if hum then hum.Sit = false end
                
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then 
                        v.CanCollide = false 
                    end
                end
                
                if root then
                    -- Triệt tiêu vận tốc rơi, giữ cố định trên đầu quái cực chuẩn
                    root.Velocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end
end)

-- Hàm Gom Quái (Bring Mob) - Tầm 2-4 con gần nhất
function BringMob(targetMobName, targetPos)
    if not _G.BringMob then return end
    pcall(function()
        local count = 0
        for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
            if v.Name == targetMobName and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                if count < 4 then -- Giới hạn 4 con để tránh lỗi
                    v.HumanoidRootPart.CanCollide = false
                    v.HumanoidRootPart.CFrame = targetPos
                    v.Humanoid.WalkSpeed = 0
                    v.Humanoid:ChangeState(11) -- Khóa trạng thái quái
                    count = count + 1
                end
            end
        end
    end)
end

-- Hàm dùng chung để bay đi mua Melee
function BuyMeleeTween(TargetCFrame, MeleeID)
    _G.FarmBone = false -- Tắt farm xương ngay lập tức
    _G.OldFarmBoneStatus = false -- Xóa bộ nhớ để nó không tự bật lại
    if _G.CurrentTween then _G.CurrentTween:Cancel() end -- Dừng các hành động bay khác

    task.spawn(function()
        local player = game.Players.LocalPlayer
        
        -- Bắt đầu bay tới NPC
        topos(TargetCFrame)
        
        -- Đợi cho đến khi bay sát NPC (khoảng cách < 15)
        repeat 
            task.wait(0.5) 
        until (player.Character.HumanoidRootPart.Position - TargetCFrame.Position).Magnitude < 15
        
        -- Khi đã đến nơi, thực hiện lệnh mua
        local remote = game:GetService("ReplicatedStorage").Remotes.CommF_
        
        if MeleeID == "BlackLeg" then remote:InvokeServer("BuyBlackLeg")
        elseif MeleeID == "Electro" then remote:InvokeServer("BuyElectro")
        elseif MeleeID == "WaterKungFu" then remote:InvokeServer("BuyFishmanKarate")
        elseif MeleeID == "Superhuman" then remote:InvokeServer("BuySuperhuman")
        elseif MeleeID == "DeathStep" then remote:InvokeServer("BuyDeathStep")
        elseif MeleeID == "Sharkman" then 
            remote:InvokeServer("BuySharkmanKarate", true)
            remote:InvokeServer("BuySharkmanKarate")
        elseif MeleeID == "DragonClaw" then remote:InvokeServer("BlackbeardReward", "DragonClaw", "1")
        elseif MeleeID == "ElectricClaw" then remote:InvokeServer("BuyElectricClaw")
        elseif MeleeID == "DragonTalon" then remote:InvokeServer("BuyDragonTalon")
        elseif MeleeID == "Godhuman" then remote:InvokeServer("BuyGodhuman")
        end
        
        print("Đã mua xong: " .. MeleeID)
    end)
end

