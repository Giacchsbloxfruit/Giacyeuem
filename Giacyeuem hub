-- Hàm hop server
function HopServer()
    local Http = game:GetService("HttpService")
    local TPS = game:GetService("TeleportService")
    local LP = game.Players.LocalPlayer
    local Api = "https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Asc&limit=100"
    
    pcall(function()
        local Raw = game:HttpGet(Api)
        local Decode = Http:JSONDecode(Raw)
        if Decode and Decode.data then
            for _, s in pairs(Decode.data) do
                if type(s) == "table" and s.id ~= game.JobId and s.playing ~= nil and s.maxPlayers ~= nil then
                    -- Kiểm tra server còn chỗ trống (ít nhất 2 chỗ để tránh bị full khi đang vào)
                    if s.playing < s.maxPlayers - 2 then
                        TPS:TeleportToPlaceInstance(game.PlaceId, s.id, LP)
                        break
                    end
                end
            end
        end
    end)
end

