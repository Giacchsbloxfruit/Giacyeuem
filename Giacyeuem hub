_G.FarmBone = false
_G.SelectWeapon = "Melee"
_G.TweenSpeed = 250
_G.BringMob = false -- Biến gom quái

local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- Hàm Tự Động Bật Haki
function AutoHaki()
    pcall(function()
        if not game.Players.LocalPlayer.Character:FindFirstChild("HasBuso") then
            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Buso")
        end
    end)
end

-- Hàm Cầm Vũ Khí
function EquipWeapon(WeaponType)
    pcall(function()
        local character = game.Players.LocalPlayer.Character
        if not character then return end
        local tool = game.Players.LocalPlayer.Backpack:FindFirstChild(WeaponType) or character:FindFirstChild(WeaponType)
        
        -- Xử lý đặc biệt cho Blox Fruit (ToolTip là "Go")
        if WeaponType == "Blox Fruit" then
            for _, v in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
                if v:IsA("Tool") and v.ToolTip == "Go" then tool = v break end
            end
        end

        if tool then character.Humanoid:EquipTool(tool) end
    end)
end

-- Hàm Noclip & Chống Rơi (Chỉ chạy khi bật Farm)
RunService.Stepped:Connect(function()
    if _G.FarmBone then
        pcall(function()
            local char = game.Players.LocalPlayer.Character
            if char then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
                -- Khóa vận tốc để không bị rơi xuống biển hoặc bị đẩy văng
                if char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end
end)

-- Hàm Tween Di Chuyển (Topos)
function topos(targetCFrame)
    local root = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local dist = (targetCFrame.p - root.Position).Magnitude
    if dist < 15 then root.CFrame = targetCFrame return end
    
    local tween = TweenService:Create(root, TweenInfo.new(dist/_G.TweenSpeed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    if not _G.FarmBone then tween:Cancel() return end
    tween:Play()
end

-- Hàm Gom Quái (Bring Mob) - Tầm 2-4 con gần nhất
function BringMob(targetMobName, targetPos)
    if not _G.BringMob then return end
    pcall(function()
        local count = 0
        for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
            if v.Name == targetMobName and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                if count < 4 then -- Giới hạn 4 con để tránh lỗi
                    v.HumanoidRootPart.CanCollide = false
                    v.HumanoidRootPart.CFrame = targetPos
                    v.Humanoid.WalkSpeed = 0
                    v.Humanoid:ChangeState(11) -- Khóa trạng thái quái
                    count = count + 1
                end
            end
        end
    end)
end

